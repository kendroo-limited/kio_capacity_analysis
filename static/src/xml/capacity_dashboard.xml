<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="kio_capacity_analysis.CapacityDashboard">
        <div class="o_kio_capacity_client_dashboard p-4">
            <div class="position-relative mb-4 text-center">
                <button type="button" class="btn btn-primary position-absolute start-0 top-50 translate-middle-y" t-on-click="() => this.openUpstreamPurchaseForm()">
                    Create
                </button>
                <h2 class="mb-1">Upstream Capacity Dashboard</h2>
                <div class="text-muted">Upstream capacity grouped by provider</div>
            </div>

            <t t-if="state.loading">
                <div class="alert alert-info">Loading capacity data...</div>
            </t>

            <t t-else="">
                <div class="row g-3 mb-4">
                    <div class="col-md-3">
                        <div class="card h-100">
                            <div class="card-body">
                                <div class="text-muted mb-1">Total Active Capacity</div>
                                <h3 class="mb-0">
                                    <t t-esc="formatNumber(state.summary.totalActiveCapacity)"/> Mbps
                                </h3>
                            </div>
                        </div>
                    </div>
                    <!-- <div class="col-md-3">
                        <div class="card h-100">
                            <div class="card-body">
                                <div class="text-muted mb-1">Total Spend</div>
                                <h3 class="mb-0">
                                    <t t-esc="formatNumber(state.summary.totalSpend)"/>
                                </h3>
                            </div>
                        </div>
                    </div> -->
                    <div class="col-md-3">
                        <div class="card h-100">
                            <div class="card-body">
                                <div class="text-muted mb-1">Total Providers</div>
                                <h3 class="mb-0">
                                    <t t-esc="state.summary.totalProviders"/>
                                </h3>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-3">
                    <t t-foreach="state.providers" t-as="provider" t-key="provider.providerId || provider.providerName">
                        <div class="col-md-3">
                            <div class="card h-100">
                                <div class="card-body d-flex flex-column">
                                    <div class="d-flex align-items-start justify-content-between mb-3">
                                        <h5 class="card-title mb-0" t-esc="provider.providerName"/>
                                        <span class="badge text-bg-secondary">
                                            <t t-esc="provider.activeCount"/>/<t t-esc="provider.totalCount"/> active
                                        </span>
                                    </div>

                                    <div class="mb-2">
                                        <div class="text-muted">Total Capacity</div>
                                        <div class="fs-4 fw-semibold">
                                            <t t-esc="formatNumber(provider.totalCapacity)"/> Mbps
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <div class="text-muted">Total Price</div>
                                        <div class="fs-5">
                                            <t t-esc="formatNumber(provider.totalPrice)"/>
                                        </div>
                                    </div>

                                    <button type="button" class="btn btn-primary mt-auto" t-on-click="() => this.openProviderPurchases(provider)">
                                        View Purchases
                                    </button>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>

                <t t-if="!state.providers.length">
                    <div class="alert alert-warning mt-4">No upstream purchases found.</div>
                </t>
            </t>
        </div>
    </t>
</templates>
