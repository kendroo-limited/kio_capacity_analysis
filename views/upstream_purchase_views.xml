<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_kio_capacity_upstream_purchase_kanban" model="ir.ui.view">
        <field name="name">kio.capacity.upstream.purchase.kanban</field>
        <field name="model">kio.capacity.upstream.purchase</field>
        <field name="arch" type="xml">
            <kanban default_group_by="provider_id" class="o_kanban_small_column">
                <field name="sequence"/>
                <field name="reference"/>
                <field name="provider_id"/>
                <field name="responsible_user_id"/>
                <field name="capacity_item"/>
                <field name="purchased_capacity"/>
                <field name="price"/>
                <field name="purchase_date"/>
                <field name="contract_start_date"/>
                <field name="contract_end_date"/>
                <field name="active"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <strong class="o_kanban_record_title">
                                    <field name="reference"/>
                                </strong>
                            </div>
                            <div class="o_kanban_record_body mt8">
                                <div>
                                    <span class="text-muted">Provider:</span>
                                    <field name="provider_id"/>
                                </div>
                                <div>
                                    <span class="text-muted">Responsible:</span>
                                    <field name="responsible_user_id"/>
                                </div>
                                <div>
                                    <span class="text-muted">Items:</span>
                                    <field name="capacity_item"/>
                                </div>
                                <div>
                                    <span class="text-muted">Total Capacity:</span>
                                    <strong><field name="purchased_capacity"/> Mbps</strong>
                                </div>
                                <div>
                                    <span class="text-muted">Total Price:</span>
                                    <field name="price"/>
                                </div>
                                <div>
                                    <span class="text-muted">Purchase Date:</span>
                                    <field name="purchase_date"/>
                                </div>
                                <div>
                                    <span class="text-muted">Contract Start:</span>
                                    <field name="contract_start_date"/>
                                </div>
                                <div>
                                    <span class="text-muted">Contract End:</span>
                                    <field name="contract_end_date"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="active" widget="boolean_toggle"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_kio_capacity_upstream_purchase_tree" model="ir.ui.view">
        <field name="name">kio.capacity.upstream.purchase.tree</field>
        <field name="model">kio.capacity.upstream.purchase</field>
        <field name="arch" type="xml">
            <tree string="Upstream Purchases" default_order="purchase_date desc, reference desc">
                <field name="sequence" widget="handle"/>
                <field name="reference" readonly="1"/>
                <field name="provider_id"/>
                <field name="responsible_user_id" widget="many2one_avatar_user"/>
                <field name="purchase_date"/>
                <field name="contract_start_date"/>
                <field name="contract_end_date"/>
                <field name="capacity_item" readonly="1"/>
                <field name="purchased_capacity" sum="Total Capacity (Mbps)" readonly="1"/>
                <field name="price" sum="Total Price" readonly="1"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>


    <record id="view_kio_capacity_upstream_purchase_search" model="ir.ui.view">
        <field name="name">kio.capacity.upstream.purchase.search</field>
        <field name="model">kio.capacity.upstream.purchase</field>
        <field name="arch" type="xml">
            <search string="Search Upstream Purchases">
                <field name="reference"/>
                <field name="provider_id"/>
                <field name="responsible_user_id"/>
                <field name="capacity_item"/>
                <field name="contract_start_date"/>
                <field name="contract_end_date"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <filter string="My Purchases" name="my_purchases" domain="[('responsible_user_id', '=', uid)]"/>
                <filter string="This Month" name="this_month" date="purchase_date" default_period="this_month"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Provider" name="group_provider" context="{'group_by': 'provider_id'}"/>
                    <filter string="Responsible Person" name="group_responsible" context="{'group_by': 'responsible_user_id'}"/>
                    <filter string="Purchase Date" name="group_purchase_date" context="{'group_by': 'purchase_date'}"/>
                    <filter string="Active Status" name="group_active" context="{'group_by': 'active'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_kio_capacity_upstream_purchase_form" model="ir.ui.view">
        <field name="name">kio.capacity.upstream.purchase.form</field>
        <field name="model">kio.capacity.upstream.purchase</field>
        <field name="arch" type="xml">
            <form string="Upstream Capacity Purchase">
                <header>
                    <button name="%(action_report_kio_capacity_upstream_purchase)d"
                            type="action"
                            string="Print PDF"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <span class="o_form_label">Upstream Purchase</span>
                        <h1>
                            <field name="reference" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Provider Information">
                            <field name="provider_id" placeholder="Select upstream provider"/>
                            <field name="purchase_date"/>
                        </group>
                        <group string="Control">
                            <field name="responsible_user_id" readonly="1"/>
                            <field name="active" invisible="1"/>
                            <field name="contract_start_date"/>
                            <field name="contract_end_date"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Capacity Items">
                            <field name="line_ids" nolabel="1">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="capacity_item_id" />
                                    <field name="purchased_capacity" sum="Total Mbps"/>
                                    <field name="price"/>
                                    <field name="total_price" sum="Total Price" readonly="1"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>

                    <group class="oe_subtotal_footer oe_right" colspan="2" string="Totals">
                        <field name="purchased_capacity" readonly="1" string="Total Capacity (Mbps)"/>
                        <field name="price" readonly="1" string="Total Price"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>


    <record id="view_kio_capacity_item_tree" model="ir.ui.view">
        <field name="name">kio.capacity.item.tree</field>
        <field name="model">kio.capacity.item</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="view_kio_capacity_item_form" model="ir.ui.view">
        <field name="name">kio.capacity.item.form</field>
        <field name="model">kio.capacity.item</field>
        <field name="arch" type="xml">
            <form string="Capacity Item">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <field name="sequence" invisible="1"/>
                        <field name="active" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_kio_capacity_item_search" model="ir.ui.view">
        <field name="name">kio.capacity.item.search</field>
        <field name="model">kio.capacity.item</field>
        <field name="arch" type="xml">
            <search string="Search Capacity Items">
                <field name="name"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_kio_capacity_item" model="ir.actions.act_window">
        <field name="name">Capacity Items</field>
        <field name="res_model">kio.capacity.item</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_kio_capacity_item_search"/>
        <field name="context">{'search_default_active': 1, 'active_test': False}</field>
    </record>

    <record id="action_kio_capacity_upstream_purchase" model="ir.actions.act_window">
        <field name="name">Total Upstream Capacity</field>
        <field name="res_model">kio.capacity.upstream.purchase</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_kio_capacity_upstream_purchase_search"/>
        <field name="context">{'search_default_active': 1, 'active_test': False, 'group_by': 'provider_id'}</field>
    </record>

    <!-- <menuitem id="menu_kio_capacity_upstream_purchase"
              name="Upstream Purchases"
              parent="menu_kio_capacity_root"
              action="action_kio_capacity_upstream_purchase"
              sequence="20"/> -->

    <menuitem id="menu_kio_capacity_configuration"
              name="Configuration"
              parent="menu_kio_capacity_root"
              sequence="90"/>

    <menuitem id="menu_kio_capacity_item"
              name="Capacity Items"
              parent="menu_kio_capacity_configuration"
              action="action_kio_capacity_item"
              sequence="10"/>

</odoo>
