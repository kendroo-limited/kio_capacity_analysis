<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_kio_capacity_dashboard_kanban" model="ir.ui.view">
        <field name="name">kio.capacity.dashboard.kanban</field>
        <field name="model">kio.capacity.dashboard</field>
        <field name="arch" type="xml">
            <kanban class="o_kio_capacity_dashboard" create="false" edit="false" delete="false">
                <field name="total_capacity"/>
                <field name="bandwidth_capacity"/>
                <field name="mac_capacity"/>
                <field name="free_capacity"/>
                <!-- New Fields -->
                <field name="upgrade_capacity"/>
                <field name="downgrade_capacity"/>
                <field name="write_date"/>

                <templates>
                    <t t-name="kanban-box">
                        <div class="o_kio_dashboard_wrapper">

                            <!-- ===== HEADER ===== -->
                            <div class="o_kio_dashboard_header">
                                <div>
                                    <div class="o_kio_breadcrumb">
                                        <span>🏠 Home</span>
                                        <i class="fa fa-chevron-right"/>
                                        <span>Capacity Analysis</span>
                                        <i class="fa fa-chevron-right"/>
                                        <span class="o_kio_breadcrumb_current">📊 Dashboard</span>
                                    </div>

                                    <h1 class="o_kio_dashboard_title">⚡ Capacity Overview</h1>
                                    <p class="o_kio_dashboard_subtitle">
                                        Real-time resource utilization and capacity metrics
                                    </p>
                                </div>

                                <div class="o_kio_header_right">
                                    <div class="o_kio_today_btn">
                                        <i class="fa fa-calendar-check-o"/>
                                        <span>Last Updated</span>
                                        <span class="o_kio_time_badge">
                                            <t t-esc="new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' })"/>
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <!-- ===== METRIC CARDS GRID ===== -->
                            <div class="o_kio_dashboard_grid">

                                <!-- 1. Total Capacity -->
                                <div class="o_kio_metric_card o_kio_metric_total">
                                    <div class="o_kio_top_line"></div>
                                    <div class="o_kio_card_glow"></div>
                                    <div class="o_kio_card_header">
                                        <div class="o_kio_metric_icon">
                                            <i class="fa fa-database"/>
                                        </div>
                                        <div class="o_kio_status_badge">
                                            <span class="o_kio_status_dot active"></span>
                                            Active
                                        </div>
                                    </div>
                                    <div class="o_kio_metric_label">Total Capacity</div>
                                    <div class="o_kio_metric_value">
                                        <span class="o_kio_number">
                                            <field name="total_capacity"/>
                                        </span>
                                        <span class="o_kio_metric_unit">Mbps</span>
                                    </div>
                                    <div class="o_kio_metric_footer">
                                        <span class="o_kio_trend_up">
                                            <i class="fa fa-arrow-up"/>
                                            +12%
                                        </span>
                                        <span class="o_kio_updated">Updated now</span>
                                    </div>
                                </div>

                                <!-- 2. Bandwidth Capacity -->
                                <a type="object" name="action_open_bandwidth_customers"
                                   class="o_kio_metric_card o_kio_metric_bandwidth o_kanban_action">
                                    <div class="o_kio_top_line"></div>
                                    <div class="o_kio_card_glow"></div>
                                    <div class="o_kio_card_header">
                                        <div class="o_kio_metric_icon">
                                            <i class="fa fa-wifi"/>
                                        </div>
                                        <div class="o_kio_status_badge">
                                            <span class="o_kio_status_dot stable"></span>
                                            Online
                                        </div>
                                    </div>
                                    <div class="o_kio_metric_label">Bandwidth Capacity</div>
                                    <div class="o_kio_metric_value">
                                        <span class="o_kio_number">
                                            <field name="bandwidth_capacity"/>
                                        </span>
                                        <span class="o_kio_metric_unit">Mbps</span>
                                    </div>
                                    <div class="o_kio_metric_footer">
                                        <span class="o_kio_trend_stable">
                                            <i class="fa fa-minus"/>
                                            Stable
                                        </span>
                                        <span class="o_kio_updated">Updated now</span>
                                    </div>
                                </a>

                                <!-- 3. MAC Capacity -->
                                <div class="o_kio_metric_card o_kio_metric_mac">
                                    <div class="o_kio_top_line"></div>
                                    <div class="o_kio_card_glow"></div>
                                    <div class="o_kio_card_header">
                                        <div class="o_kio_metric_icon">
                                            <i class="fa fa-server"/>
                                        </div>
                                        <div class="o_kio_status_badge">
                                            <span class="o_kio_status_dot warning"></span>
                                            Online
                                        </div>
                                    </div>
                                    <div class="o_kio_metric_label">MAC Capacity</div>
                                    <div class="o_kio_metric_value">
                                        <span class="o_kio_number">
                                            <field name="mac_capacity"/>
                                        </span>
                                        <span class="o_kio_metric_unit">Units</span>
                                    </div>
                                    <div class="o_kio_metric_footer">
                                        <span class="o_kio_trend_up">
                                            <i class="fa fa-arrow-up"/>
                                            +8%
                                        </span>
                                        <span class="o_kio_updated">Updated now</span>
                                    </div>
                                </div>

                                <!-- 4. Free Capacity -->
                                <div class="o_kio_metric_card o_kio_metric_free">
                                    <div class="o_kio_top_line"></div>
                                    <div class="o_kio_card_glow"></div>
                                    <div class="o_kio_card_header">
                                        <div class="o_kio_metric_icon">
                                            <i class="fa fa-check-circle"/>
                                        </div>
                                        <div class="o_kio_status_badge">
                                            <span class="o_kio_status_dot active"></span>
                                            Available
                                        </div>
                                    </div>
                                    <div class="o_kio_metric_label">Free Capacity</div>
                                    <div class="o_kio_metric_value">
                                        <span class="o_kio_number">
                                            <field name="free_capacity"/>
                                        </span>
                                        <span class="o_kio_metric_unit">Mbps</span>
                                    </div>
                                    <div class="o_kio_metric_footer">
                                        <span class="o_kio_trend_up">
                                            <i class="fa fa-arrow-up"/>
                                            +5%
                                        </span>
                                        <span class="o_kio_updated">Updated now</span>
                                    </div>
                                </div>

                                <!-- 5. Upgrade Capacity -->
                                <a type="object" name="action_open_upgrade_requests"
                                   class="o_kio_metric_card o_kio_metric_upgrade o_kanban_action">
                                    <div class="o_kio_top_line"></div>
                                    <div class="o_kio_card_glow"></div>
                                    <div class="o_kio_card_header">
                                        <div class="o_kio_metric_icon">
                                            <i class="fa fa-level-up"/>
                                        </div>
                                        <div class="o_kio_status_badge">
                                            <span class="o_kio_status_dot success"></span>
                                            Recommended
                                        </div>
                                    </div>
                                    <div class="o_kio_metric_label">Upgrade Capacity</div>
                                    <div class="o_kio_metric_value">
                                        <span class="o_kio_number">
                                            <field name="upgrade_capacity"/>
                                        </span>
                                        <span class="o_kio_metric_unit">Mbps</span>
                                    </div>
                                    <div class="o_kio_metric_footer">
                                        <span class="o_kio_trend_up">
                                            <i class="fa fa-arrow-up"/>
                                            +15%
                                        </span>
                                        <span class="o_kio_updated">Updated now</span>
                                    </div>
                                </a>

                                <!-- 6. Downgrade Capacity -->
                                <a type="object" name="action_open_downgrade_requests"
                                   class="o_kio_metric_card o_kio_metric_downgrade o_kanban_action">
                                    <div class="o_kio_top_line"></div>
                                    <div class="o_kio_card_glow"></div>
                                    <div class="o_kio_card_header">
                                        <div class="o_kio_metric_icon">
                                            <i class="fa fa-level-down"/>
                                        </div>
                                        <div class="o_kio_status_badge">
                                            <span class="o_kio_status_dot warning"></span>
                                            Optimization
                                        </div>
                                    </div>
                                    <div class="o_kio_metric_label">Downgrade Capacity</div>
                                    <div class="o_kio_metric_value">
                                        <span class="o_kio_number">
                                            <field name="downgrade_capacity"/>
                                        </span>
                                        <span class="o_kio_metric_unit">Mbps</span>
                                    </div>
                                    <div class="o_kio_metric_footer">
                                        <span class="o_kio_trend_down">
                                            <i class="fa fa-arrow-down"/>
                                            -8%
                                        </span>
                                        <span class="o_kio_updated">Updated now</span>
                                    </div>
                                </a>

                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Action with Search View Disabled -->
    <record id="action_kio_capacity_dashboard" model="ir.actions.act_window">
        <field name="name">Capacity Dashboard</field>
        <field name="res_model">kio.capacity.dashboard</field>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="view_kio_capacity_dashboard_kanban"/>
        <field name="target">current</field>
        <field name="context">{'search_view_enabled': False}</field>
    </record>

    <record id="view_kio_capacity_dashboard_customer_tree" model="ir.ui.view">
        <field name="name">kio.capacity.dashboard.customer.tree</field>
        <field name="model">kio.capacity.dashboard.customer</field>
        <field name="arch" type="xml">
            <tree create="false" edit="false">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="client_type"/>
                <field name="bandwidth_capacity"/>
                <field name="total_capacity"/>
                <field name="offer_total_price"/>
                <field name="confirmed_date"/>
            </tree>
        </field>
    </record>

    <record id="view_kio_capacity_dashboard_customer_form" model="ir.ui.view">
        <field name="name">kio.capacity.dashboard.customer.form</field>
        <field name="model">kio.capacity.dashboard.customer</field>
        <field name="arch" type="xml">
            <form string="Customer Capacity Details" create="false" edit="false">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="partner_id"/>
                            <field name="client_type"/>
                            <field name="confirmed_date"/>
                        </group>
                    </group>

                    <group string="Capacity Summary">
                        <field name="bandwidth_capacity"/>
                        <field name="total_capacity"/>
                        <field name="offer_total_price"/>
                    </group>

                    <notebook>
                        <page string="Offer Bandwidth Details">
                            <field name="offer_capacity_detail_ids" readonly="1">
                                <tree>
                                    <field name="capacity"/>
                                    <field name="buffer_bandwidth"/>
                                    <field name="offer_price"/>
                                    <field name="offer_total_price"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_kio_capacity_root"
              name="Capacity Analysis"
              web_icon="kio_capacity_analysis,static/description/icon.png"
              sequence="10"/>

    <menuitem id="menu_kio_capacity_dashboard"
              name="Dashboard"
              parent="menu_kio_capacity_root"
              action="action_kio_capacity_dashboard"
              sequence="10"/>

</odoo>