<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_kio_capacity_dashboard_kanban" model="ir.ui.view">
        <field name="name">kio.capacity.dashboard.kanban</field>
        <field name="model">kio.capacity.dashboard</field>
        <field name="arch" type="xml">
            <kanban class="kio_capacity_dashboard" create="false" edit="false" delete="false">
                <field name="total_upstream_capacity"/>
                <field name="total_capacity"/>
                <field name="free_capacity"/>
                <field name="bandwidth_capacity"/>
                <field name="mac_capacity"/>
<!--                <field name="nttn_capacity"/>-->
                <field name="upgrade_capacity"/>
                <field name="downgrade_capacity"/>
                <field name="write_date"/>

                <templates>
                    <t t-name="kanban-box">
                        <div class="kio_capacity_shell">
                            <div class="kio_capacity_header">
                                <div class="kio_capacity_header_left">
                                    <div class="kio_capacity_breadcrumb">
                                        <span>Home</span>
                                        <i class="fa fa-chevron-right"/>
                                        <span>Capacity Analysis</span>
                                        <i class="fa fa-chevron-right"/>
                                        <span class="kio_capacity_breadcrumb_current">Dashboard</span>
                                    </div>
                                    <h1 class="kio_capacity_title">Capacity Overview</h1>
                                    <p class="kio_capacity_subtitle">Real-time resource utilization and capacity metrics</p>
                                </div>

                                <div class="kio_capacity_updated_badge">
                                    <i class="fa fa-calendar-check-o"/>
                                    <span>Last Updated</span>
                                    <span class="kio_capacity_updated_time">
                                        <t t-esc="new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' })"/>
                                    </span>
                                </div>
                            </div>

                            <div class="kio_capacity_grid">
                                <a type="object" name="action_open_upstream_purchases"
                                   class="kio_capacity_card kio_capacity_card_blue o_kanban_action">
                                    <div class="kio_capacity_card_topline"></div>
                                    <div class="kio_capacity_card_header">
                                        <div class="kio_capacity_icon kio_capacity_icon_blue">
                                            <i class="fa fa-upload"/>
                                        </div>
                                        <div class="kio_capacity_status">
                                            <span class="kio_capacity_status_dot kio_capacity_status_active"></span>
                                            <span>Active</span>
                                        </div>
                                    </div>
                                    <div class="kio_capacity_label">Total Upstream Capacity</div>
                                    <div class="kio_capacity_value_row">
                                        <span class="kio_capacity_value"><field name="total_upstream_capacity"/></span>
                                        <span class="kio_capacity_unit">Mbps</span>
                                    </div>
                                </a>

                                <div class="kio_capacity_card kio_capacity_card_blue">
                                    <div class="kio_capacity_card_topline"></div>
                                    <div class="kio_capacity_card_header">
                                        <div class="kio_capacity_icon kio_capacity_icon_blue">
                                            <i class="fa fa-download"/>
                                        </div>
                                        <div class="kio_capacity_status">
                                            <span class="kio_capacity_status_dot kio_capacity_status_active"></span>
                                            <span>Active</span>
                                        </div>
                                    </div>
                                    <div class="kio_capacity_label">Total Downstream Capacity</div>
                                    <div class="kio_capacity_value_row">
                                        <span class="kio_capacity_value"><field name="total_capacity"/></span>
                                        <span class="kio_capacity_unit">Mbps</span>
                                    </div>
                                </div>

                                <div class="kio_capacity_card kio_capacity_card_green">
                                    <div class="kio_capacity_card_topline"></div>
                                    <div class="kio_capacity_card_header">
                                        <div class="kio_capacity_icon kio_capacity_icon_green">
                                            <i class="fa fa-check-circle"/>
                                        </div>
                                        <div class="kio_capacity_status">
                                            <span class="kio_capacity_status_dot kio_capacity_status_available"></span>
                                            <span>Available</span>
                                        </div>
                                    </div>
                                    <div class="kio_capacity_label">Free Capacity</div>
                                    <div class="kio_capacity_value_row">
                                        <span class="kio_capacity_value"><field name="free_capacity"/></span>
                                        <span class="kio_capacity_unit">Mbps</span>
                                    </div>
                                </div>

                                <a type="object" name="action_open_bandwidth_customers"
                                   class="kio_capacity_card kio_capacity_card_cyan o_kanban_action">
                                    <div class="kio_capacity_card_topline"></div>
                                    <div class="kio_capacity_card_header">
                                        <div class="kio_capacity_icon kio_capacity_icon_cyan">
                                            <i class="fa fa-wifi"/>
                                        </div>
                                        <div class="kio_capacity_status">
                                            <span class="kio_capacity_status_dot kio_capacity_status_online"></span>
                                            <span>Online</span>
                                        </div>
                                    </div>
                                    <div class="kio_capacity_label">Bandwidth Capacity</div>
                                    <div class="kio_capacity_value_row">
                                        <span class="kio_capacity_value"><field name="bandwidth_capacity"/></span>
                                        <span class="kio_capacity_unit">Mbps</span>
                                    </div>
                                </a>

                                <div class="kio_capacity_card kio_capacity_card_purple">
                                    <div class="kio_capacity_card_topline"></div>
                                    <div class="kio_capacity_card_header">
                                        <div class="kio_capacity_icon kio_capacity_icon_purple">
                                            <i class="fa fa-server"/>
                                        </div>
                                        <div class="kio_capacity_status">
                                            <span class="kio_capacity_status_dot kio_capacity_status_warning"></span>
                                            <span>Online</span>
                                        </div>
                                    </div>
                                    <div class="kio_capacity_label">MAC Capacity</div>
                                    <div class="kio_capacity_value_row">
                                        <span class="kio_capacity_value"><field name="mac_capacity"/></span>
                                        <span class="kio_capacity_unit">Units</span>
                                    </div>
                                </div>

                                <div class="kio_capacity_card kio_capacity_card_orange">
                                    <div class="kio_capacity_card_topline"></div>
                                    <div class="kio_capacity_card_header">
                                        <div class="kio_capacity_icon kio_capacity_icon_orange">
                                            <i class="fa fa-sitemap"/>
                                        </div>
                                        <div class="kio_capacity_status">
                                            <span class="kio_capacity_status_dot kio_capacity_status_online"></span>
                                            <span>Active</span>
                                        </div>
                                    </div>
                                    <div class="kio_capacity_label">NTTN Capacity</div>
                                    <div class="kio_capacity_value_row">
                                        <span class="kio_capacity_value">
<!--                                            <field name="nttn_capacity"/>-->
                                        </span>
                                        <span class="kio_capacity_unit">Mbps</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_kio_capacity_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">kio.capacity.dashboard</field>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="view_kio_capacity_dashboard_kanban"/>
        <field name="target">current</field>
        <field name="context">{'search_view_enabled': False}</field>
    </record>

    <record id="view_kio_capacity_dashboard_customer_tree" model="ir.ui.view">
        <field name="name">kio.capacity.dashboard.customer.tree</field>
        <field name="model">kio.capacity.dashboard.customer</field>
        <field name="arch" type="xml">
            <tree create="false" edit="false">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="client_type"/>
                <field name="bandwidth_capacity"/>
                <field name="total_capacity"/>
                <field name="offer_total_price"/>
                <field name="confirmed_date"/>
            </tree>
        </field>
    </record>

    <record id="view_kio_capacity_dashboard_customer_form" model="ir.ui.view">
        <field name="name">kio.capacity.dashboard.customer.form</field>
        <field name="model">kio.capacity.dashboard.customer</field>
        <field name="arch" type="xml">
            <form string="Customer Capacity Details" create="false" edit="false">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="partner_id"/>
                            <field name="client_type"/>
                            <field name="confirmed_date"/>
                        </group>
                    </group>

                    <group string="Capacity Summary">
                        <field name="bandwidth_capacity"/>
                        <field name="total_capacity"/>
                        <field name="offer_total_price"/>
                    </group>

                    <notebook>
                        <page string="Offer Bandwidth Details">
                            <field name="offer_capacity_detail_ids" readonly="1">
                                <tree>
                                    <field name="capacity"/>
                                    <field name="buffer_bandwidth"/>
                                    <field name="offer_price"/>
                                    <field name="offer_total_price"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <menuitem id="menu_kio_capacity_root"
              name="Capacity Analysis"
              web_icon="kio_capacity_analysis,static/description/icon.png"
              sequence="10"/>

    <menuitem id="menu_kio_capacity_dashboard"
              name="Dashboard"
              parent="menu_kio_capacity_root"
              action="action_kio_capacity_dashboard"
              sequence="10"/>


</odoo>