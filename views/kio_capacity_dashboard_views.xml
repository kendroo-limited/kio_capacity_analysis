<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_kio_capacity_dashboard_form" model="ir.ui.view">
        <field name="name">kio.capacity.dashboard.form</field>
        <field name="model">kio.capacity.dashboard</field>
        <field name="arch" type="xml">
            <form string="Capacity Dashboard">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>

                    <group>
                        <field name="total_capacity"/>
                        <field name="bandwidth_capacity"/>
                        <field name="mac_capacity"/>
                        <field name="free_capacity"/>
                    </group>

                    <notebook>
                        <page string="Customer Capacity Details">
                            <field name="customer_line_ids" readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="client_type"/>
                                    <field name="bandwidth_capacity"/>
                                    <field name="mac_capacity"/>
                                    <field name="total_capacity"/>
                                    <field name="offer_total_price"/>
                                    <field name="confirmed_date"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_kio_capacity_dashboard_tree" model="ir.ui.view">
        <field name="name">kio.capacity.dashboard.tree</field>
        <field name="model">kio.capacity.dashboard</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="total_capacity"/>
                <field name="bandwidth_capacity"/>
                <field name="mac_capacity"/>
                <field name="free_capacity"/>
            </tree>
        </field>
    </record>

    <record id="view_kio_capacity_dashboard_customer_form" model="ir.ui.view">
        <field name="name">kio.capacity.dashboard.customer.form</field>
        <field name="model">kio.capacity.dashboard.customer</field>
        <field name="arch" type="xml">
            <form string="Customer Capacity Details">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="partner_id"/>
                            <field name="client_type"/>
                            <field name="confirmed_date"/>
                        </group>
                        <group>
                            <field name="survey_id"/>
                            <field name="work_order_id"/>
                            <field name="transmission_id"/>
                        </group>
                    </group>

                    <group string="Capacity Summary">
                        <field name="bandwidth_capacity"/>
                        <field name="mac_capacity"/>
                        <field name="total_capacity"/>
                        <field name="offer_total_price"/>
                    </group>

                    <notebook>
                        <page string="Offer Bandwidth Details">
                            <field name="offer_capacity_detail_ids" readonly="1">
                                <tree>
                                    <field name="type_id"/>
                                    <field name="capacity"/>
                                    <field name="buffer_bandwidth"/>
                                    <field name="offer_price"/>
                                    <field name="offer_total_price"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_kio_capacity_dashboard_customer_tree" model="ir.ui.view">
        <field name="name">kio.capacity.dashboard.customer.tree</field>
        <field name="model">kio.capacity.dashboard.customer</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="client_type"/>
                <field name="bandwidth_capacity"/>
                <field name="total_capacity"/>
                <field name="offer_total_price"/>
                <field name="survey_id"/>
                <field name="work_order_id"/>
                <field name="confirmed_date"/>
            </tree>
        </field>
    </record>

    <record id="action_kio_capacity_dashboard" model="ir.actions.act_window">
        <field name="name">Capacity Dashboard</field>
        <field name="res_model">kio.capacity.dashboard</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_kio_capacity_dashboard_customer" model="ir.actions.act_window">
        <field name="name">Customer Capacity Details</field>
        <field name="res_model">kio.capacity.dashboard.customer</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>