<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="kio_capacity_analysis.CapacityDashboard">
        <div class="o_kio_capacity_client_dashboard p-4">
            <div class="position-relative mb-4 text-center">
                <button type="button" class="btn btn-primary position-absolute start-0 top-50 translate-middle-y" t-on-click="() => this.openCapacityItemForm()">
                    Create
                </button>
                <div class="d-inline-block">
                    <h2 class="mb-1">Upstream Capacity Dashboard</h2>
                    <div class="text-muted">Vendor bill quantity grouped by service product</div>
                </div>
                <div class="position-absolute end-0 top-0 d-flex align-items-end gap-2 text-start">
                    <div>
                        <label class="form-label mb-1" for="capacity_date_from">Start Date</label>
                        <input id="capacity_date_from" type="date" class="form-control" t-att-value="state.dateFrom" t-on-change="(ev) => this.onDateRangeChange('dateFrom', ev.target.value)"/>
                    </div>
                    <div>
                        <label class="form-label mb-1" for="capacity_date_to">End Date</label>
                        <input id="capacity_date_to" type="date" class="form-control" t-att-value="state.dateTo" t-on-change="(ev) => this.onDateRangeChange('dateTo', ev.target.value)"/>
                    </div>
                    <button type="button" class="btn btn-outline-secondary" t-att-disabled="!state.dateFrom &amp;&amp; !state.dateTo" t-on-click="() => this.clearDateRange()">
                        Clear
                    </button>
                </div>
            </div>

            <t t-if="state.loading">
                <div class="alert alert-info">Loading capacity data...</div>
            </t>

            <t t-else="">
                <div class="row g-3 mb-4">
                    <div class="col-md-3">
                        <div class="card h-100">
                            <div class="card-body">
                                <div class="text-muted mb-1">Total Vendor Bill Quantity</div>
                                <h3 class="mb-0">
                                    <t t-esc="formatNumber(state.summary.totalActiveCapacity)"/> Mbps
                                </h3>
                            </div>
                        </div>
                    </div>
                    <!-- <div class="col-md-3">
                        <div class="card h-100">
                            <div class="card-body">
                                <div class="text-muted mb-1">Total Spend</div>
                                <h3 class="mb-0">
                                    <t t-esc="formatNumber(state.summary.totalSpend)"/>
                                </h3>
                            </div>
                        </div>
                    </div> -->
                    <div class="col-md-3">
                        <div class="card h-100">
                            <div class="card-body">
                                <div class="text-muted mb-1">Service Products</div>
                                <h3 class="mb-0">
                                    <t t-esc="state.summary.totalCapacityItems"/>
                                </h3>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-3">
                    <t t-foreach="state.capacityItems" t-as="item" t-key="item.itemId || item.itemName">
                        <div class="col-md-3">
                            <div class="card h-100">
                                <div class="card-body d-flex flex-column">
                                    <div class="d-flex align-items-start justify-content-between mb-3">
                                        <h5 class="card-title mb-0" t-esc="item.itemName"/>
                                        <span t-att-class="item.active ? 'badge text-bg-success' : 'badge text-bg-secondary'">
                                            <t t-esc="item.active ? 'Active' : 'Archived'"/>
                                        </span>
                                    </div>

                                    <div class="mb-2">
                                        <div class="text-muted">Sales Quantity</div>
                                        <div class="fs-4 fw-semibold">
                                            <t t-esc="formatNumber(item.totalCapacity)"/> Mbps
                                        </div>
                                    </div>

                                    <div class="mb-2">
                                        <div class="text-muted">Vendor Bill Amount</div>
                                        <div class="fs-5">
                                            <t t-esc="formatNumber(item.totalPrice)"/>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <div class="text-muted">Vendor Bill Lines</div>
                                        <div class="fs-6">
                                            <t t-esc="item.purchaseCount"/>
                                        </div>
                                    </div>

                                    <button type="button" class="btn btn-primary mt-auto" t-on-click="() => this.openCapacityItemPurchases(item)">
                                        View Vendor Bill Lines
                                    </button>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>

                <t t-if="!state.capacityItems.length">
                    <div class="alert alert-warning mt-4">No capacity items found.</div>
                </t>
            </t>
        </div>
    </t>
</templates>
