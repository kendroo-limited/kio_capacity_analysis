<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_kio_capacity_upstream_purchase_kanban" model="ir.ui.view">
        <field name="name">kio.capacity.upstream.purchase.kanban</field>
        <field name="model">kio.capacity.upstream.purchase</field>
        <field name="arch" type="xml">
            <kanban default_group_by="provider_id" class="o_kanban_small_column">
                <field name="sequence"/>
                <field name="reference"/>
                <field name="provider_id"/>
                <field name="responsible_user_id"/>
                <field name="capacity_item"/>
                <field name="purchased_capacity"/>
                <field name="price"/>
                <field name="purchase_date"/>
                <field name="active"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <strong class="o_kanban_record_title">
                                    <field name="reference"/>
                                </strong>
                            </div>
                            <div class="o_kanban_record_body mt8">
                                <div>
                                    <span class="text-muted">Provider:</span>
                                    <field name="provider_id"/>
                                </div>
                                <div>
                                    <span class="text-muted">Responsible:</span>
                                    <field name="responsible_user_id"/>
                                </div>
                                <div>
                                    <span class="text-muted">Items:</span>
                                    <field name="capacity_item"/>
                                </div>
                                <div>
                                    <span class="text-muted">Total Capacity:</span>
                                    <strong><field name="purchased_capacity"/> Mbps</strong>
                                </div>
                                <div>
                                    <span class="text-muted">Total Price:</span>
                                    <field name="price"/>
                                </div>
                                <div>
                                    <span class="text-muted">Purchase Date:</span>
                                    <field name="purchase_date"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="active" widget="boolean_toggle"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_kio_capacity_upstream_purchase_tree" model="ir.ui.view">
        <field name="name">kio.capacity.upstream.purchase.tree</field>
        <field name="model">kio.capacity.upstream.purchase</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="reference" readonly="1"/>
                <field name="provider_id"/>
                <field name="responsible_user_id"/>
                <field name="capacity_item" readonly="1"/>
                <field name="purchased_capacity" sum="Total Mbps" readonly="1"/>
                <field name="price" sum="Total Price" readonly="1"/>
                <field name="purchase_date"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_kio_capacity_upstream_purchase_form" model="ir.ui.view">
        <field name="name">kio.capacity.upstream.purchase.form</field>
        <field name="model">kio.capacity.upstream.purchase</field>
        <field name="arch" type="xml">
            <form string="Upstream Capacity Purchase">
                <sheet>
                    <div class="oe_title">
                        <span class="o_form_label">Upstream Purchase</span>
                        <h1>
                            <field name="reference" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Provider Information">
                            <field name="provider_id" placeholder="Select upstream provider"/>
                            <field name="purchase_date"/>
                        </group>
                        <group string="Control">
                            <field name="responsible_user_id"/>
                            <field name="active"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Capacity Items">
                            <field name="line_ids" nolabel="1">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="capacity_item" placeholder="Internet Bandwidth"/>
                                    <field name="purchased_capacity" sum="Total Mbps"/>
                                    <field name="price"/>
                                    <field name="total_price" sum="Total Price" readonly="1"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>

                    <group class="oe_subtotal_footer oe_right" colspan="2">
                        <field name="capacity_item" readonly="1"/>
                        <field name="purchased_capacity" readonly="1"/>
                        <field name="price" readonly="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_kio_capacity_upstream_purchase" model="ir.actions.act_window">
        <field name="name">Total Upstream Capacity</field>
        <field name="res_model">kio.capacity.upstream.purchase</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="context">{'group_by': 'provider_id'}</field>
    </record>

    <menuitem id="menu_kio_capacity_upstream_purchase"
              name="Upstream Purchases"
              parent="menu_kio_capacity_root"
              action="action_kio_capacity_upstream_purchase"
              sequence="20"/>

</odoo>
